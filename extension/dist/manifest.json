{
  "manifest_version": 3,
  "name": "PromptMemory Chrome Extension",
  "version": "1.0.0",
  "description": "Bridge between AI Conversations and PromptMemory SaaS",
  "icons": {
    "16": "icon128.png",
    "48": "icon128.png",
    "128": "icon128.png"
  },
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "action": {
    "default_title": "PromptMemory Quick Actions",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "js": [
        "assets/chatgpt.ts-6Iwlb5i1.js"
      ],
      "matches": [
        "https://chatgpt.com/*"
      ],
      "run_at": "document_end"
    },
    {
      "js": [
        "assets/authBridge.ts-D3AttJgB.js"
      ],
      "matches": [
        "https://prompt-memory.vercel.app/*",
        "https://*.vercel.app/*",
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*"
      ],
      "run_at": "document_end"
    },
    {
      "js": [
        "assets/floatingLogo.ts-Bdx69Dox.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_end"
    },
    {
      "js": [
        "assets/youtube.ts-DuQ7Wmpg.js"
      ],
      "matches": [
        "*://*.youtube.com/*"
      ],
      "run_at": "document_end"
    },
    {
      "js": [
        "assets/gemini.ts-vz5WP4we.js"
      ],
      "matches": [
        "*://gemini.google.com/*",
        "https://gemini.google.com/*"
      ],
      "run_at": "document_end"
    },
    {
      "js": [
        "assets/socialClipper.ts-CLqks-2V.js"
      ],
      "matches": [
        "*://*.linkedin.com/*",
        "*://*.instagram.com/*",
        "*://*.twitter.com/*",
        "*://*.x.com/*"
      ],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "resources": [
        "popup.html",
        "assets/*",
        "icon128.png"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "resources": [
        "assets/chatgpt.ts-6Iwlb5i1.js"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "http://127.0.0.1:3000/*",
        "http://localhost:3000/*",
        "https://*.vercel.app/*",
        "https://prompt-memory.vercel.app/*"
      ],
      "resources": [
        "assets/authBridge.ts-D3AttJgB.js"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "assets/floatingLogo.ts-Bdx69Dox.js"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "resources": [
        "assets/youtube.ts-DuQ7Wmpg.js"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "*://gemini.google.com/*",
        "https://gemini.google.com/*"
      ],
      "resources": [
        "assets/gemini.ts-vz5WP4we.js"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "*://*.instagram.com/*",
        "*://*.linkedin.com/*",
        "*://*.twitter.com/*",
        "*://*.x.com/*"
      ],
      "resources": [
        "assets/socialClipper.ts-CLqks-2V.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
